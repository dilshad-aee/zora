# ──────────────────────────────────────────────────────────────────
# Zora Music — Environment Variables
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
ZORA_BASE_URL=https://your-app.onrender.com

# ─── Admin Account (created on first run) ─────────────────────────
ZORA_ADMIN_EMAIL=your-admin@email.com
ZORA_ADMIN_PASSWORD=your-secure-password

# ─── Google OAuth (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email / SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Cloudflare R2 Storage ───────────────────────────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=zora-music
# Public URL: Enable public access on the bucket, or use a custom domain
# Example: https://pub-xxxx.r2.dev  OR  https://cdn.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
